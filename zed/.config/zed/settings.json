// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "edit_predictions": {
    "provider": "zed"
  },
  "prettier": {
    "allowed": true
  },
  "agent": {
    "tool_permissions": {
      "tools": {
        "terminal": {
          "always_allow": [
            {
              "pattern": "^rg\\s+PtyOutput(\\s|$)"
            },
            {
              "pattern": "^cat\\b"
            },
            {
              "pattern": "^sed\\b"
            },
            {
              "pattern": "^find\\s+src(\\s|$)"
            }
          ]
        }
      }
    },
    "dock": "right",
    "default_model": {
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5"
    }
  },
  "ui_font_size": 18,
  "buffer_font_size": 18,
  "minimap": {
    "show": "auto"
  },
  "tabs": {
    "file_icons": true,
    "git_status": true
  },
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "fish",
        "args": ["-l"]
      }
    }
  },
  "windows": {
    "terminal": {
      "shell": {
        "with_arguments": {
          "program": "powershell.exe",
          "args": ["-NoLogo"]
        }
      }
    }
  },
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Frappé",
    "dark": "Catppuccin Frappé"
  },
  "ui_font_family": "Maple Mono",
  "buffer_font_family": "Maple Mono",
  "extend_comment_on_newline": false
}
